|    | read_row:
|0461|     MOVC                              ;; Load 8-bit mask | ROM-Loading POINT (2) >>>
|0462|     MOV          0x07,  A             ;; Save 8-bit mask to 0x07
|0463|     MOV          A,     #0x0e         ;; Set waiting time (14 times)
|0464|     CALL         func_0140            ;; Delay function
|0465|     B0MOV        A,     P1            ;; Read column buffer values (P0.0-0.7)
|0466|     XOR          A,     #0xff         ;; Convert active-low to be active-high
|0467|     AND          A,     0x07          ;; Mask the read column buffer values
|0468|     MOV          0x08,  A             ;; Save the masked raw bits to 0x08
|0469|     MOV          A,     #0x7a         ;; 
|046a|     ADD          Z,     A             ;; Get Z val of RAM address where the row bits to be saved
|046b|     MOV          A,     0x08          ;; A: masked raw bits
|046c|     B0MOV        @YZ,   A             ;; Store at RAM. RAM[0x0100 + 0] = columns
|046d|     MOV          A,     #0x87         ;; 
|046e|     ADD          Z,     A             ;; Increment Z val
|046f|     RET                               ;;

|    | key_scan:                             ; Key-scanning
|0470|     B0MOV        Y,     #0x01         ; Y = #0x01
|0471|     B0MOV        Z,     #0x86         ; Z = #0x86 (for ROM, not RAM)
|0472|     B0BSET       P2M.2                ; ---------- [row 7] Set port 2.2 to be output mode.
|0473|     B0BCLR       P2.2                 ; Set port 2.2 buffer low
|0474|     CALL         read_row             ;; Read row and store in Y = #0x01, Z = #0x00
|0475|     B0BSET       P2.2                 ; Set port 2.2 buffer high
|0476|     B0BCLR       P2M.2                ; Set port 2.2 to be input mode.
|0477|     B0BSET       P2M.0                ; ---------- [row 5] Set port 2.0 to be output mode.
|0478|     B0BCLR       P2.0                 ; Set port 2.0 buffer low
|0479|     CALL         read_row             ;; Read row and store in Y = #0x01, Z = #0x01
|047a|     B0BSET       P2.0                 ; Set port 2.0 buffer high
|047b|     B0BCLR       P2M.0                ; Set port 2.0 to be input mode.
|047c|     B0BSET       P4M.0                ; ---------- [row 9] P4.0 
|047d|     B0BCLR       P4.0                 ; Set port 4.0 buffer low
|047e|     CALL         read_row             ;;
|047f|     B0BSET       P4.0                 ;
|0480|     B0BCLR       P4M.0                ; P4.0
|0481|     B0BSET       P4M.5                ; ---------- [row 14] P4.5
|0482|     B0BCLR       P4.5                 ;
|0483|     CALL         read_row             ;;
|0484|     B0BSET       P4.5                 ;
|0485|     B0BCLR       P4M.5                ; P4.5
|0486|     B0BSET       P4M.1                ; ---------- [row 10] P4.1
|0487|     B0BCLR       P4.1                 ;
|0488|     CALL         read_row             ;;
|0489|     B0BSET       P4.1                 ;
|048a|     B0BCLR       P4M.1                ; P4.1
|048b|     B0BSET       P2M.1                ; ---------- [row 06] P2.1
|048c|     B0BCLR       P2.1                 ;
|048d|     CALL         read_row             ;;
|048e|     B0BSET       P2.1                 ;
|048f|     B0BCLR       P2M.1                ; P2.1
|0490|     B0BSET       P4M.4                ; ---------- [row 13] P4.4
|0491|     B0BCLR       P4.4                 ;
|0492|     CALL         read_row             ;;
|0493|     B0BSET       P4.4                 ;
|0494|     B0BCLR       P4M.4                ; P4.4
|0495|     B0BSET       P4M.2                ; ---------- [row 11] P4.2
|0496|     B0BCLR       P4.2                 ;
|0497|     CALL         read_row             ;;
|0498|     B0BSET       P4.2                 ;
|0499|     B0BCLR       P4M.2                ; P4.2
|049a|     B0BSET       P4M.3                ; ---------- [row 12] P4.3
|049b|     B0BCLR       P4.3                 ;
|049c|     CALL         read_row             ;;
|049d|     B0BSET       P4.3                 ;
|049e|     B0BCLR       P4M.3                ; P4.3
|049f|     B0BSET       P2M.3                ; ---------- [row 08] P2.3
|04a0|     B0BCLR       P2.3                 ;
|04a1|     CALL         read_row             ;;
|04a2|     B0BSET       P2.3                 ;
|04a3|     B0BCLR       P2M.3                ; P2.3
|04a4|     B0BSET       P0M.5                ; ---------- [row 03] P0.5
|04a5|     B0BCLR       P0.5                 ;
|04a6|     CALL         read_row             ;;
|04a7|     B0BSET       P0.5                 ;
|04a8|     B0BCLR       P0M.5                ; P0.5
|04a9|     B0BSET       P0M.4                ; ---------- [row 02] P0.4
|04aa|     B0BCLR       P0.4                 ;
|04ab|     CALL         read_row             ;;
|04ac|     B0BSET       P0.4                 ;
|04ad|     B0BCLR       P0M.4                ; P0.4
|04ae|     B0BSET       P4M.6                ; ---------- [row 15] P4.6
|04af|     B0BCLR       P4.6                 ;
|04b0|     CALL         read_row             ;;
|04b1|     B0BSET       P4.6                 ;
|04b2|     B0BCLR       P4M.6                ; P4.6
|04b3|     B0BSET       P4M.7                ; ---------- [row 16] P4.7
|04b4|     B0BCLR       P4.7                 ;
|04b5|     CALL         read_row             ;;
|04b6|     B0BSET       P4.7                 ;
|04b7|     B0BCLR       P4M.7                ; P4.7
|04b8|     B0BSET       P0M.3                ; ---------- [row 01] P0.3
|04b9|     B0BCLR       P0.3                 ;
|04ba|     CALL         read_row             ;;
|04bb|     B0BSET       P0.3                 ;
|04bc|     B0BCLR       P0M.3                ; P0.3
|04bd|     B0BSET       P0M.6                ; ---------- [row 04] P0.6
|04be|     B0BCLR       P0.6                 ;
|04bf|     CALL         read_row             ;;
|04c0|     B0BSET       P0.6                 ;
|04c1|     B0BCLR       P0M.6                ; P0.6
|04c2|     CLR          0x07                 ;
|04c3|     CLR          0x08                 ;
|    | func_0186_00b4:                       ; === Ghosting / abnormal multi-key detection phase (entry) ===
|04c4|     CALL         func_04eb            ; Set Y=0x01, Z=0x00 -> point to current scan buffer RAM[0x0100..]
|04c5|     MOV          A,     0x07          ; A = row index (row_i)
|04c6|     ADD          Z,     A             ; Z = 0x00 + row_i -> RAM[0x0100 + row_i]
|04c7|     B0MOV        A,     @YZ           ; A = column bit pattern of row_i (8-bit)
|04c8|     MOV          0x09,  A             ; Save current row pattern into 0x09
|04c9|     MOV          R,     A             ; save x to R
|04ca|     SUB          A,     #0x01         ; A = x - 1
|04cb|     AND          A,     R             ; A = x & (x - 1)
|04cc|     B0BTS0       FZ                   ; if Z==1 => <=1 set bits
|04cd|     JMP          func_0186_00cf       ; If popcount <= 1 (single or no key), skip comparison and go to next row
|04ce|     INCMS        0x08                 ; popcount >= 2 -> initialize secondary row index (row_j++)
|04cf|     NOP                               ;
|    | func_0186_00c0:                       ; === Compare row_i with other rows (row_j loop) ===
|04d0|     CALL         func_04eb            ; Reset Y=0x01, Z=0x00 -> current scan buffer
|04d1|     MOV          A,     0x08          ; A = secondary row index (row_j)
|04d2|     ADD          Z,     A             ; Z = 0x00 + row_j
|04d3|     B0MOV        A,     @YZ           ; A = column bit pattern of row_j
|04d4|     AND          A,     0x09          ; A = pattern(row_i)
|04d5|     MOV          R,     A             ; save x to R
|04d6|     SUB          A,     #0x01         ; A = x - 1
|04d7|     AND          A,     R             ; A = x & (x - 1)
|04d8|     B0BTS0       FZ                   ; if Z==1 => <=1 set bits
|04d9|     JMP          func_0186_00c7       ; If one or zero, continue scanning other rows
|04da|     JMP          func_0186_010a       ; JMP func_0186_00df ; If two or more, suspicious pattern detected

|    | func_0186_00c7:                       ; === Advance to next row_j ===
|04db|     INCMS        0x08                 ; row_j++
|04dc|     NOP                               ;
|04dd|     MOV          A,     #0x0f         ; A = 15 (maximum row index)
|04de|     SUB          A,     0x08          ; A = 15 - row_j
|04df|     B0BTS0       FC                   ; Check if row_j <= 15
|04e0|     JMP          func_0186_00c0       ; If still within range, continue comparison
|04e1|     MOV          A,     0x07          ; Reset row_j to row_i
|04e2|     MOV          0x08,  A             ;
|    | func_0186_00cf:                       ; === Advance to next row_i ===
|04e3|     INCMS        0x07                 ; row_i++
|04e4|     NOP                               ;
|04e5|     INCMS        0x08                 ; row_j++
|04e6|     NOP                               ;
|04e7|     MOV          A,     #0x0e         ; A = 14 (last row index to check)
|04e8|     SUB          A,     0x07          ; A = 14 - row_i
|04e9|     B0BTS0       FC                   ; Check if row_i <= 14
|04ea|     JMP          func_0186_00b4       ; Continue scanning remaining rows
|04eb|     CALL         func_02a1            ; Clear working registers 0x09, 0x0a, 0x0b, 0x0c
|04ec|     BCLR         0x00.4               ; Clear abnormal-processing flag
|04ed|     CLR          0x07                 ; Reset row_i index
|04ee|     CLR          0x08                 ; Reset row_j index
|04ef|     CLR          0x0e                 ; Clear row offset pointer
|04f0|     MOV          A,     #0x01         ;
|04f1|     MOV          0x0d,  A             ; Reset bit-processing counter
|04f2|     JMP          func_0186_0120       ; Resume normal key change processing

|    | func_0186_010a:                       ; === Unrecoverable ghosting -> full reset ===
|04f3|     BTS0         0x00.4               ; Check if reset already performed
|04f4|     JMP          func_02a1            ; If yes, silently return
|04f5|     BSET         0x00.4               ; Mark reset performed
|04f6|     BSET         0x13.0               ; Request report update
|04f7|     BSET         0x00.2               ; Set special-state flag
|04f8|     B0MOV        Y,     #0x01         ;
|04f9|     B0MOV        Z,     #0x20         ;
|    | func_0186_0111:                       ;
|04fa|     CLR          @YZ                  ; Clear RAM[0x0120..] (key state buffer)
|04fb|     INCMS        Z                    ;
|04fc|     NOP                               ;
|04fd|     MOV          A,     #0x29         ;
|04fe|     SUB          A,     Z             ;
|04ff|     B0BTS0       FC                   ;
|0500|     JMP          func_0186_0111       ;
|0501|     CLR          0x15                 ; Clear modifier state
|0502|     CALL         func_011f            ; Send all-keys-released report
|0503|     BSET         0x00.5               ; Request resynchronization
|    | func_02a1:                            ; === Clear working variables ===
|0504|     CLR          0x09                 ;
|0505|     CLR          0x0a                 ;
|0506|     CLR          0x0b                 ;
|0507|     CLR          0x0c                 ;
|0508|     RET                               ;

|    | func_0186_0120:                       ; === Normal key change detection ===
|0509|     BCLR         0x00.2               ; Clear special-state flag
|050a|     CALL         func_04eb            ; Point to current scan buffer
|050b|     MOV          A,     0x07          ; 
|050c|     ADD          Z,     A             ;
|050d|     B0MOV        A,     @YZ           ;
|050e|     B0BTS0       FZ                   ; Check if row data is zero
|050f|     JMP          func_0186_012d       ;
|0510|     MOV          0x09,  A             ; Save current row data
|0511|     MOV          0x0c,  A             ;
|0512|     BSET         0x00.2               ; Mark valid row detected
|0513|     MOV          A,     #0x0a         ;
|0514|     MOV          0x44,  A             ;
|0515|     JMP          func_0186_012f       ;

|    | func_0186_012d:                       ;
|0516|     MOV          0x09,  A             ; Store current row data
|0517|     MOV          0x0c,  A             ;
|    | func_0186_012f:                       ;
|0518|     CALL         func_04ee            ; Point to previous scan buffer
|0519|     MOV          A,     0x07          ;
|051a|     ADD          Z,     A             ;
|051b|     B0MOV        A,     @YZ           ;
|051c|     MOV          0x0a,  A             ; Load previous row data
|051d|     MOV          A,     0x09          ;
|051e|     CMPRS        A,     0x0a          ; Compare current vs previous
|051f|     JMP          func_0186_0138       ;
|0520|     JMP          func_0186_013b       ;

|    | func_0186_0138:                       ; === No change ===
|0521|     MOV          A,     0x09          ;
|0522|     B0MOV        @YZ,   A             ; Update previous buffer
|0523|     JMP          func_0186_02d1       ;

|    | func_0186_013b:                       ; === Change detected (generate diff) ===
|0524|     CALL         func_04f1            ; Prepare diff buffer
|0525|     MOV          A,     0x07          ;
|0526|     ADD          Z,     A             ;
|0527|     B0MOV        A,     @YZ           ;
|0528|     MOV          0x0a,  A             ;
|0529|     CLR          0x0b                 ;
|052a|     MOV          A,     0x09          ;
|052b|     XOR          A,     0x0a          ; diff = current XOR previous
|052c|     B0BTS0       FZ                   ;
|052d|     JMP          func_0186_02d1       ;
|052e|     MOV          0x0b,  A             ; Store changed bits mask
|    | func_0186_0146:                       ;
|052f|     BTS1         0x0b.0               ; Check 0x0b.0
|0530|     JMP          func_0186_02c3       ; If 0x0b.0 == 0, ===> JMP func_0186_02c3
|0531|     BCLR         0x00.3               ; If 0x0b.0 == 1, set 0x00.3 = 0
|0532|     BTS1         0x09.0               ; Check 0x09.0
|0533|     BSET         0x00.3               ; If 0x09.0 == 0, set 0x00.3 = 1
|0534|     MOV          A,     0x0e          ;
|0535|     ADD          A,     0x0d          ; A = 0x0e + 0x0d
|0536|     MOV          0x08,  A             ; 0x08 = 0x0e + 0x0d
|0537|     B0MOV        Y,     #0x01         ; Y = #0x01 (changed from #0x05)
|0538|     B0MOV        Z,     #0x96         ; Z = #0x96 (changed from #0xa0)
|0539|     MOV          A,     0x08          ;
|053a|     ADD          Z,     A             ; Z = 0x08 + Z
|053b|     B0BTS0       FC                   ; Carry-up trematment
|053c|     INCMS        Y                    ; Y = #0x01 or #0x02, Z = #0x96 + 0x08
|053d|     MOVC                              ; Load key ID of the pressed key | ROM-Loading POINT (3) >>>
|053e|     MOV          0x0f,  A             ; 0x0f = A (LOWER byte)
|053f|     BTS0         0x00.7               ;; Check Mod key flag
|0540|     JMP          get_L2_key           ;; Jump to 2nd layer function
|    | process_a:                            ;;
|0541|     BTS1         0x00.3               ;; Check 0x00.3 (What flag ?)
|0542|     JMP          func_0186_015c       ;; If 0x00.3 == 0, JMP 015c
|0543|     CALL         func_054f            ;; If 0x00.3 == 1, CALL func_054f (Clear 0x42, and do many things before return.)
|0544|     B0BTS0       FC                   ;; Check the carry flag
|0545|     JMP          func_0186_02c3       ;; If FC == 1, JMP 02c3 (Common fucntion) ===> JMP func_0186_02c3
|0546|     JMP          func_0186_015f       ;; If FC == 0, JMP 015f (Fx and Fn + X key process) ---> Route B

|    | get_L2_key:                           ;;
|0547|     MOV          A,     R             ;; 
|0548|     MOV          0x0f,  A             ;; 0x0f = R (HIGHER byte)
|0549|     JMP          process_a            ;; 

|    | func_0186_015c:                       ;
|054a|     CALL         func_04fd            ; Clear 0x41, and do many things before return.
|054b|     B0BTS0       FC                   ; Carry flag of 'ADD Z, A' in the func_0186_0146.
|054c|     JMP          func_0186_02c3       ; If FC == 1, JMP 02c3 (Common fucntion) ===> JMP func_0186_02c3
|    | func_0186_015f:                       ; If FC == 0, JMP 015f (Fx and Fn + X key process) ---> Route B
|054d|     MOV          A,     0x0f          ;
|054e|     CMPRS        A, #0x${s/fn_id/af} ;; Compare with Fn key. default: #0xaf
|054f|     JMP          func_0186_016e       ; If 0x0f is not "Fn", Go to func_0186_016e
|0550|     B0MOV        A,     0x74          ; If 0x0f is "Fn", get value of 0x74
|0551|     B0BTS0       FZ                   ; Check FZ flag (if 0x74 == 0)
|0552|     RET                               ; if 0x74 == 0, RETURN
|0553|     BCLR         0x00.0               ; 0x00.0 = 0
|0554|     BTS1         0x00.3               ; Check 0x00.3 (What flag ?)
|0555|     BSET         0x00.0               ; If 0x00.3 == 0, 0x00.0 = 1 ( Fn key pressed flag ? ).
|0556|     BSET         0x13.0               ; 0x13.0 = 1  13.0 Modifier key pressed flag
|0557|     BSET         0x13.4               ; 0x13.4 = 1	13.4 ? will be activated when ESC, Fx, ...
|0558|     BSET         0x13.6               ; 0x13.6 = 1	13.6 ? will be activated when ESC, Fx, ....
|0559|     BSET         0x13.7               ; 0x13.7 = 1	13.7 ? 
|055a|     JMP          key_categorization   ;;

|    | func_0186_016e:                       ; [ Fn + B --> Break (Ctrl + P) ]
|055b|     BTS1         0x00.0               ; Check 0x00.0
|055c|     JMP          func_0186_0198       ; If 0x00.0 == 0, JMP to 0198 (Normal key process)
|055d|     CMPRS        A,     #0x05         ;; Compare with #0x05 (B key)
|055e|     JMP          func_0186_0180       ;; if not, Go to [ Fn + S --> Alt + PrtScn or SysReq ]
|055f|     BSET         0x12.5               ;; Something to emit Break
|0560|     BSET         0x13.0               ;; Something to emit Break
|0561|     CLR          0x3f                 ;; Clear 0x3f flag
|0562|     JMP          func_0186_02c3       ;; JMP to func_0186_02c3

|    | func_0186_0180:                       ; [ Fn + S --> Alt + PrtScn or SysReq ]
|0563|     CMPRS        A,     #0x16         ; Compare with #0x16 (S key)
|0564|     JMP          func_0186_0186       ; If not, Go to [ Fn + Esc --> Toggle FnLk ]
|0565|     B0BSET       0x14.3               ; Something to emit SysReq
|0566|     B0BSET       0x13.0               ; Something to emit SysReq
|0567|     CLR          0x3f                 ; Clear 0x3f flag
|0568|     JMP          func_0186_02c3       ; JMP to func_0186_02c3

|    | func_0186_0186:                       ; [ Fn + Esc --> Toggle FnLk ]
|0569|     CMPRS        A,     #0x29         ; Compare with #0x29 (ESC key)
|056a|     JMP          func_0186_0198       ; If not, JMP to 0198
|056b|     BTS1         0x00.3               ; Check 0x00.3
|056c|     JMP          func_0186_018e       ; If 0x00.3 == 0, JMP
|056d|     BSET         0x13.6               ; If 0x00.3 == 1, set 0x13.6 = 1
|056e|     CLR          0x28                 ; , and 0x28 = 00
|056f|     CLR          0x29                 ; , and 0x29 = 00
|0570|     JMP          func_0186_02c3       ; JMP to func_0186_02c3

|    | func_0186_018e:                       ; [ If 0x00.3 == 0]
|0571|     BSET         0x13.6               ; Set 0x13.6 = 1
|0572|     MOV          A,     #0x02         ; 
|0573|     MOV          0x29,  A             ; Set 0x29 = 02
|0574|     CLR          0x28                 ; Set 0x28 = 00
|0575|     BSET         0x13.5               ; Set 0x13.5 = 1
|0576|     BSET         0x13.0               ; Set 0x13.0 = 1
|0577|     BSET         0x13.4               ; Set 0x13.4 = 1
|0578|     CLR          0x21                 ; Set 0x21 = 00
|0579|     CLR          0x22                 ; Set 0x22 = 00
|057a|     JMP          func_0186_02c3       ; JMP to func_0186_02c3

|    | func_0186_0198:                       ;
|057b|     B0MOV        A,     0x74          ; Get value of 0x74
|057c|     B0BTS0       FZ                   ; Check Flag Zero
|057d|     JMP          key_categorization   ;;
|057e|     MOV          A,     0x00          ; If FZ == 1, Get lower two-digit of 0x00 value 
|057f|     AND          A,     #0x03         ; (0x00.0: Fn pressed signal, 0x00.1: Fnlock signal from PC).
|0580|     B0ADD        PCL,   A             ;
|0581|     JMP          key_categorization   ;; if A == 0 (00), Key-type categorization
|0582|     JMP          f1_mute              ;  if A == 1 (01), Media key process
|0583|     JMP          f1_mute              ;  if A == 2 (10), Media key process
|0584|     JMP          key_categorization   ;; if A == 3 (11), Key-type categorization

|    | f1_mute:                              ; [F1 Mute]
|0585|     MOV          A,     0x0f          ;
|0586|     B0MOV        Y,     #0x02         ; Common Y value
|0587|     CMPRS        A,     #0x3a         ; Check 0x0f value is F1
|0588|     JMP          f2_vol_down          ; if not, Go to [F2 vol --]
|0589|     B0MOV        Z,     #0x17         ;;
|058a|     JMP          consumer_key         ;;

|    | f2_vol_down:                          ; [F2 vol --]
|058b|     CMPRS        A,     #0x3b         ; Check 0x0f value is F2
|058c|     JMP          f3_vol_up            ; if not, Go to [F3 vol ++]
|058d|     B0MOV        Z,     #0x18         ;;
|058e|     JMP          consumer_key         ;;

|    | f3_vol_up:                            ; [F3 vol ++]
|058f|     CMPRS        A,     #0x3c         ; Check 0x0f value is F3
|0590|     JMP          f4_mic_mute_pre      ; if not, Go to [F4 Mic Mute]
|0591|     B0MOV        Z,     #0x19         ;;
|0592|     JMP          consumer_key         ;;

|    | f4_mic_mute_pre:
|0593|     CMPRS        A,     #0x3d         ; Check 0x0f value is F4
|0594|     JMP          f5_brightness_dn_pre ; if not, Go to F5
|0595|     JMP          f4_mic_mute          ;

|    | f4_mic_mute:                          ; [F4 Mic Mute]
|0596|     B0MOV        Z,     #0x1a         ;;
|0597|     JMP          special_key          ;;

|    | f5_brightness_dn_pre:                 ;
|0598|     CMPRS        A,     #0x3e         ; Check 0x0f value is F5
|0599|     JMP          f6_brightness_up_pre ; if not, Go to F6
|059a|     JMP          f5_brightness_down   ; if not, Go to F6

|    | f5_brightness_down:                   ; [F5 brightness down]
|059b|     BTS1         0x12.2               ; Check 0x12.2
|059c|     JMP          f5_brightness_down_b ; If 0x12.2 == 0, JMP to branch
|059d|     B0MOV        Z,     #0x1b         ;;
|059e|     JMP          special_key          ;;

|    | f5_brightness_down_b:                 ; [F5 brightness down]
|059f|     BTS1         0x12.3               ; Check 0x12.3
|05a0|     JMP          func_0186_02c3       ; If 0x12.2 == 0, Go to 02c3
|05a1|     B0MOV        Z,     #0x1c         ;;
|05a2|     JMP          consumer_key         ;; 

|    | f6_brightness_up_pre:
|05a3|     CMPRS        A,     #0x3f         ; Check 0x0f value is F6
|05a4|     JMP          f7_process_pre       ; if not, Go to F7
|05a5|     JMP          f6_brightness_up     ;

|    | f6_brightness_up:                     ; [F6 brightness up]
|05a6|     BTS1         0x12.2               ; Check 0x12.2
|05a7|     JMP          f6_brightness_up_b   ; If 0x12.2 == 0, JMP to branch
|05a8|     B0MOV        Z,     #0x1d         ;;
|05a9|     JMP          special_key          ;;

|    | f6_brightness_up_b:                   ; [F6 brightness up]
|05aa|     BTS1         0x12.3               ; Check 0x12.3
|05ab|     JMP          func_0186_02c3       ; If 0x12.2 == 0, Go to 02c3
|05ac|     B0MOV        Z,     #0x1e         ;;
|05ad|     JMP          consumer_key         ;;

|    | f7_process_pre:
|05ae|     CMPRS        A,     #0x40         ;
|05af|     JMP          f8_process_pre       ;
|05b0|     JMP          f7_process           ;  

|    | f7_process:                           ; [F7]
|05b1|     B0BTS0       0x14.7               ;
|05b2|     JMP          func_0186_020d       ;
|05b3|     B0BTS1       0x12.0               ;
|05b4|     JMP          func_0186_0217       ;
|    | func_0186_020d:                       ;
|05b5|     B0MOV        Z,     #0x1f         ;;
|05b6|     JMP          special_key          ;;
    
|    | func_0186_0217:                       ; [F7]
|05b7|     B0BTS0       0x12.2               ;
|05b8|     JMP          func_0186_021b       ;
|05b9|     B0BTS1       0x12.3               ;
|05ba|     JMP          func_0186_02c3       ;
|    | func_0186_021b:                       ;
|05bb|     BSET         0x40.4               ;
|05bc|     BSET         0x13.0               ;
|05bd|     CLR          0x3f                 ;
|05be|     JMP          func_0186_02c3       ;

|    | f8_process_pre:
|05bf|     CMPRS        A,     #0x41         ;
|05c0|     JMP          f9_process_pre       ;
|05c1|     JMP          f8_process           ;

|    | f8_process:                           ; [F8]
|05c2|     BTS1         0x12.3               ;
|05c3|     JMP          func_0186_022e       ;
|05c4|     B0MOV        Z,     #0x20         ;;
|05c5|     JMP          consumer_key         ;;

|    | func_0186_022e:                       ; [F8]
|05c6|     B0MOV        Z,     #0x21         ;;
|05c7|     JMP          special_key          ;;

|    | f9_process_pre:
|05c8|     CMPRS        A,     #0x42         ;
|05c9|     JMP          f10_process_pre      ;
|05ca|     JMP          f9_process           ;

|    | f9_process:                           ; [F9]
|05cb|     BTS1         0x12.3               ;
|05cc|     JMP          func_0186_023f       ;
|05cd|     BSET         0x40.6               ;
|05ce|     BSET         0x13.0               ;
|05cf|     CLR          0x3f                 ;
|    | func_0186_023f:                       ;
|05d0|     B0MOV        Z,     #0x22         ;;
|05d1|     JMP          special_key          ;;

|    | f10_process_pre:
|05d2|     CMPRS        A,     #0x43         ;
|05d3|     JMP          f11_process_pre      ;
|05d4|     JMP          f10_process          ;

|    | f10_process:                          ; [F10]
|05d5|     B0MOV        Z,     #0x23         ;;
|05d6|     JMP          consumer_key         ;;

|    | f11_process_pre:                      ; 
|05d7|     CMPRS        A,     #0x44         ;
|05d8|     JMP          f12_process_pre      ;
|05d9|     JMP          f11_process          ;

|    | f11_process:                          ; [F11]
|05da|     BTS0         0x12.0               ;
|05db|     JMP          func_0186_025d       ;
|05dc|     BSET         0x40.7               ;
|05dd|     BSET         0x13.0               ;
|05de|     CLR          0x3f                 ;
|    | func_0186_025d:                       ;
|05df|     B0MOV        Z,     #0x24         ;;
|05e0|     JMP          special_key          ;;

|    | f12_process_pre:
|05e1|     CMPRS        A,     #0x45         ; Check 0x0f value is F12
|05e2|     JMP          key_categorization   ;; If not F12, go to key categorization
|05e3|     JMP          f12_process          ;

|    | f12_process:                          ; [F12]
|05e4|     BTS1         0x12.3               ; If F12, 0x12.3 flag check
|05e5|     JMP          func_0186_0273       ; If 0x12.3 == 0, JMP to func_0186_0273
|05e6|     BSET         0x13.4               ; If 0x12.3 == 1, 
|05e7|     BTS0         0x00.3               ; 0x00.3 flag check
|05e8|     JMP          func_0186_027b       ; If 0x00.3 == 1, JMP to func_0186_027b
|05e9|     MOV          A,     #0xf2         ; 
|05ea|     MOV          0x21,  A             ; 0x21 = #0xf2
|05eb|     MOV          A,     #0x03         ;
|05ec|     MOV          0x22,  A             ; 0x22 = #0x03
|05ed|     JMP          func_0186_02c3       ; ===> JMP func_0186_02c3

|    | func_0186_0273:                       ; [F12]
|05ee|     BSET         0x13.6               ; 0x13.6 = 1
|05ef|     BTS0         0x00.3               ; Check 0x00.3
|05f0|     JMP          func_0186_027b       ; If 0x00.3 == 1, JMP to func_0186_027b
|05f1|     MOV          A,     #0x94         ; If 0x00.3 == 0,
|05f2|     MOV          0x28,  A             ; 0x28 = #0x94
|05f3|     MOV          A,     #0x01         ; 
|05f4|     MOV          0x29,  A             ; 0x29 = #0x01
|05f5|     JMP          func_0186_02c3       ; ===> JMP func_0186_02c3

|    | func_0186_027b:                       ;
|05f6|     CLR          0x28                 ; 0x28 = #0x00
|05f7|     CLR          0x29                 ; 0x29 = #0x00
|05f8|     CLR          0x21                 ; 0x21 = #0x00
|05f9|     CLR          0x22                 ; 0x22 = #0x00
|05fa|     JMP          func_0186_02c3       ; ===> JMP func_0186_02c3

|    | consumer_key:
|05fb|     BSET         0x13.4               ;; Set 0x13.4 = 1
|05fc|     BTS0         0x00.3               ;; Check 0x00.3
|05fd|     B0MOV        Z,     #0x27         ;; ROM address for 0x0000
|05fe|     MOVC                              ;; Load consumer key byte pair | ROM-Loading POINT (4) >>>
|05ff|     MOV          0x21,  A             ;; 0x21 = LOWER byte
|0600|     MOV          A,     R             ;; 
|0601|     MOV          0x22,  A             ;; 0x22 = R (HIGHER byte)
|0602|     JMP          func_0186_02c3       ;;
              
|    | special_key:
|0603|     BSET         0x13.6               ;; Set 0x13.6 = 1
|0604|     BTS0         0x00.3               ;; Check 0x00.3
|0605|     B0MOV        Z,     #0x27         ;; ROM address for 0x0000
|0606|     MOVC                              ;; Load special functional key byte pair | ROM-Loading POINT (5) >>>
|0607|     MOV          0x28,  A             ;; 0x28 = LOWER byte
|0608|     MOV          A,     R             ;; 
|0609|     MOV          0x29,  A             ;; 0x29 = R (HIGHER byte)
|060a|     JMP          func_0186_02c3       ;;

|    | key_categorization:                   ;
|060b|     B0MOV        Y,     #0x02         ;; Common Y value
|060c|     MOV          A,     0x0f          ;;
|060d|     SUB          A,     #0xcd         ;;
|060e|     B0BTS1       FC                   ;;
|060f|     JMP          func_0186_02be       ;;
|0610|     SUB          A,     #0x08         ;;
|0611|     B0BTS1       FC                   ;;
|0612|     JMP          function_key         ;;
|0613|     SUB          A,     #0x0b         ;;
|0614|     B0BTS1       FC                   ;;
|0615|     JMP          application_key      ;;
|0616|     SUB          A,     #0x08         ;;
|0617|     B0BTS1       FC                   ;;
|0618|     JMP          modifier_key         ;;
|0619|     BSET         0x13.0               ;;
|061a|     B0MOV        Z,     #0x28         ;; Macro key ROM address
|061b|     ADD          Z,     A             ;; 
|061c|     MOVC                              ;; Load macro key ID (lower byte) and modifier key state (higher byte) | ROM-Loading POINT (6) >>>
|061d|     MOV          0x0f,  A             ;;
|061e|     MOV          A,     R             ;; [hgfedcba] a: LeftControl, b: LeftShift, c: LeftAlt, d: LeftGUI, e: RightControl, f: RightShift, g: RightAlt, h: RightGUI
|061f|     BTS0         0x00.3               ;;
|0620|     JMP          macro_key_released   ;;
|0621|     JMP          macro_key_pressed    ;;

|    | application_key:
|0622|     ADD          A,     #0x0b         ;;    
|0623|     BSET         0x13.4               ;; ------- Custom counsumer key --------
|0624|     B0MOV        Z,     #0x40         ;; -------------------------------------
|0625|     ADD          Z,     A             ;;
|0626|     BTS0         0x00.3               ;; -------------------------------------
|0627|     B0MOV        Z,     #0x27         ;; ROM address for 0x0000
|0628|     MOVC                              ;; Load custom consumer key byte pair | ROM-Loading POINT (7) >>>
|0629|     MOV          0x21,  A             ;; -------------------------------------
|062a|     MOV          A,     R             ;; -------------------------------------
|062b|     MOV          0x22,  A             ;; -------------------------------------
|062c|     JMP          func_0186_02c3       ;; -------------------------------------

|    | function_key:
|062d|     ADD          A,     #0x08         ;; 
|062e|     B0ADD        PCL,   A             ;;
